---
import { SOCIALS } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Socials from "@components/Socials.astro";

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <div class="flex flex-col items-center justify-center sm:flex-row">
        <img
          src="/assets/headshot.jpg"
          alt="Jessica Shi"
          class="mb-4 mr-8 w-1/3 rounded-3xl object-cover sm:mb-0 sm:aspect-[2/3]"
        />
        <div>
          <h2
            id="title"
            class="relative w-[max-content] font-sans before:absolute before:inset-0 before:animate-typewriter before:bg-skin-fill after:absolute after:inset-0 after:w-[0.125em] after:animate-caret after:bg-skin-base"
          >
            hi i'm jessica 👋
          </h2>

          <p>
            I'm a second-year <b>PhD Student in Operations Management</b> at New
            York University Stern School of Business. I work with Professors Divya
            Singhvi and Somya Singhvi on LLM-assisted decision-making. My primary
            interests are in behavioral operations, human-AI collaboration, and the
            societal impacts of technology. I hope to design better interfaces for
            non-technical users to benefit from operations methods
            and AI. I graduated from Columbia University in 2024 with a degree in
            operations research.
          </p>
          <p>email: jjs9997 at stern.nyu.edu</p>
          <p>
            <LinkButton
              className="underline decoration-dashed underline-offset-4 hover:text-skin-accent"
              href="/main_2026.pdf"
            >
              CV
            </LinkButton>
          </p>
          {
            socialCount > 0 && (
              <div class="social-wrapper">
                <div class="social-links">Social Links:</div>
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <Hr />

    <section class="mb-10 mt-10" id="updates">
      <h2 id="section-title">-updates-</h2>
      <ul class="update-list">
        <li class="update-item">
          <span class="update-date">July 2026</span>
          <span class="update-sep">—</span>
          MSOM 2026 @ Harvard Business School; Accepted to Technology, Innovation, and Entrepreneurship SIG Day
        </li>
        <li class="update-item">
          <span class="update-date">May 2026</span>
          <span class="update-sep">—</span>
          AI-SCORE @ UIUC
        </li>
        <li class="update-item">
          <span class="update-date">May 2026</span>
          <span class="update-sep">—</span>
          POMS 2026 @ Reno, NV; Finalist in the College of Behavioral Operations Management Junior Scholar Paper Competition

        </li>
        <li class="update-item">
          <span class="update-date">April 2026</span>
          <span class="update-sep">—</span>
          NYC Operations Day 2025 @ Baruch College
        </li>
        <li class="update-item">
          <span class="update-date">October 2025</span>
          <span class="update-sep">—</span>
          INFORMS 2024 @ Atlanta, Georgia
        </li>
      </ul>
    </section>

    <Hr />
  </main>

  <Footer />
</Layout>

<style>
  #hero {
    @apply pb-6 pt-8;
  }
  #hero p {
    @apply my-2;
  }
  .social-wrapper {
    @apply mt-4 flex flex-col sm:flex-row sm:items-center;
  }
  .social-links {
    @apply mb-1 mr-2 whitespace-nowrap sm:mb-0;
  }
  #section-title {
    @apply mb-4 text-center text-2xl font-semibold tracking-wide;
  }
  #title {
    @apply text-3xl;
  }
  .update-list {
    @apply mt-3 list-none p-0;
  }
  .update-item {
    @apply flex items-baseline gap-3 py-2;
  }
  .update-date {
    @apply min-w-[110px] text-sm font-semibold;
  }
  .update-sep {
    @apply text-skin-accent;
  }
</style>
